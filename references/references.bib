% =============================================================
% 1. ESCALAS DE MEDIDA E CLASSIFICAÇÃO DE VARIÁVEIS
% =============================================================

% --- Stevens (1946): O artigo clássico na Science que definiu as quatro
%     escalas de medida (nominal, ordinal, intervalar, razão). Um dos
%     artigos mais citados da história da estatística. ---
@article{stevens1946,
  author    = {Stevens, Stanley Smith},
  title     = {On the Theory of Scales of Measurement},
  journal   = {Science},
  volume    = {103},
  number    = {2684},
  pages     = {677--680},
  year      = {1946},
  doi       = {10.1126/science.103.2684.677},
  publisher = {American Association for the Advancement of Science}
}

% --- Velleman & Wilkinson (1993): Artigo provocativo no American
%     Statistician que questiona a taxonomia de Stevens, mostrando
%     que a classificação NOIR é mais nuançada do que parece. ---
@article{velleman1993,
  author    = {Velleman, Paul F. and Wilkinson, Leland},
  title     = {Nominal, Ordinal, Interval, and Ratio Typologies Are Misleading},
  journal   = {The American Statistician},
  volume    = {47},
  number    = {1},
  pages     = {65--72},
  year      = {1993},
  doi       = {10.1080/00031305.1993.10475938}
}

% --- Michell (1986): Artigo influente no Psychological Bulletin sobre
%     o conflito entre escalas de medida e testes estatísticos. ---
@article{michell1986,
  author    = {Michell, Joel},
  title     = {Measurement Scales and Statistics: {A} Clash of Paradigms},
  journal   = {Psychological Bulletin},
  volume    = {100},
  number    = {3},
  pages     = {398--407},
  year      = {1986},
  doi       = {10.1037/0033-2909.100.3.398}
}

% --- Chrisman (1998): Rethinking levels of measurement —
%     propõe extensões à taxonomia de Stevens com novos níveis. ---
@article{chrisman1998,
  author    = {Chrisman, Nicholas R.},
  title     = {Rethinking Levels of Measurement for Cartography},
  journal   = {Cartography and Geographic Information Science},
  volume    = {25},
  number    = {4},
  pages     = {231--242},
  year      = {1998},
  doi       = {10.1559/152304098782383043}
}


